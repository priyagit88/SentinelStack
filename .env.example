# Copy this file to .env.local and fill in real values.
# Real .env.local is gitignored and must NEVER be committed.
# In production (Vercel), set these in the project's Environment Variables panel.

# ── MongoDB (required) ──────────────────────────────────────────────────────
MONGODB_URI=

# ── better-auth (required) ──────────────────────────────────────────────────
# BETTER_AUTH_URL drives the OAuth redirect_uri sent to Google/GitHub.
# Dev:  http://localhost:3000
# Prod: https://sentinel-stack-seven.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# ── AI threat analysis via Groq (optional — falls back to heuristics) ───────
# Free API key from https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override. Default: llama-3.3-70b-versatile.
# For higher quality on the free tier you can use: openai/gpt-oss-120b
GROQ_MODEL=

# ── OAuth providers (optional but recommended) ──────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI must include:
#   <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App → Authorization callback URL must equal:
#   <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Admin allowlist (legacy email-based /api access) ────────────────────────
# Comma-separated emails. /admin access is now primarily gated by wallet role
# (see SentinelAccess contract). This list is kept for backwards compatibility.
ADMIN_EMAILS=

# ── Transactional email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=

# ── Google reCAPTCHA v3 ─────────────────────────────────────────────────────
# Site key is registered with allowed domains in the reCAPTCHA admin console.
# Must include sentinel-stack-seven.vercel.app for production.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Minimum v3 score (0.0–1.0) to accept a token. Default 0.3 is permissive
# for fresh keys; raise to 0.5 once Google has calibrated traffic.
RECAPTCHA_MIN_SCORE=0.3

# ── Web3 Forensic Audit Trail (optional / local testnet) ──────────────────
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
NEXT_PUBLIC_CONTRACT_ADDRESS=

# ── World ID (proof-of-personhood registration, Feature 2) ────────────────
# Create at https://developer.worldcoin.org → Apps
# App ID from the dev portal (e.g. app_staging_xxx). The NEXT_PUBLIC_ variant
# ships to the browser for the IDKit widget; the non-public variant stays
# server-side for verifyCloudProof.
WORLD_ID_APP_ID=app_your_app_id_from_dev_portal
NEXT_PUBLIC_WORLD_ID_APP_ID=
# Action name configured for this app in the World ID dev portal.
WORLD_ID_ACTION=sentinel_register
NEXT_PUBLIC_WORLD_ID_ACTION=sentinel_register

# ── Wallet-Based Admin Access (SentinelAccess contract, Feature 6) ─────────
# Address of the deployed SentinelAccess.sol contract (role-based admin gate).
NEXT_PUBLIC_SENTINEL_ACCESS_CONTRACT=
# WalletConnect Cloud project ID — create one at https://cloud.walletconnect.com
# Required for RainbowKit wallet connection (even on local/testnet).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Optional: comma-separated initial admin addresses for the deploy script.
# Defaults to Hardhat accounts 0 and 1 when running on localhost.
INITIAL_ADMIN_ADDRESSES=

# ── Base Sepolia testnet (for production deployments) ──────────────────────
# Set BLOCKCHAIN_RPC_URL to an Alchemy/Infura Base Sepolia endpoint and use:
#   npx hardhat run scripts/deploy.js --network baseSepolia
#   npx hardhat run scripts/deploy-access.js --network baseSepolia
